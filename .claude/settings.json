{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.brain/hooks/on-session-start.sh\"",
            "async": false,
            "timeout": 20
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.brain/hooks/on-session-end.sh\"",
            "async": true,
            "timeout": 20
          }
        ]
      }
    ]
  }
}
